#!/bin/bash
set -e
echo Activating Virtual Env

if [ "$(uname -s | grep -i 'mingw\|msys\|cygwin')" ]; then
    BIN_DIR="Scripts"
else
    BIN_DIR="bin"
fi

. .venv/${BIN_DIR}/activate

echo Running Tests

pytest -x
npm run test

echo Code Quality Checks

# --preview enables rules outside the project's ruff.toml that the upstream
# code does not satisfy; stick to the configured ruleset.
ruff check
ruff format --check --preview
npx eslint ./src

echo Pre Push Completed
